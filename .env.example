#############################################
# Docker project
#############################################

PROJECT=wakapi_stack

#############################################
# Container names (must be unique to avoid conflicts)
#############################################

WAKAPI_APP_CONTAINER=wakapi_app
WAKAPI_DB_CONTAINER=wakapi_postgres

#############################################
# Docker images
#############################################

WAKAPI_IMAGE=ghcr.io/muety/wakapi:latest
POSTGRES_IMAGE=postgres:16

#############################################
# Network / volumes
#############################################

WAKAPI_NETWORK=wakapi_net
POSTGRES_VOLUME=wakapi_pgdata

#############################################
# Public domain (IMPORTANT)
#############################################

WAKAPI_PUBLIC_URL=https://wakapi.example.fr

#############################################
# Wakapi configuration
#############################################

WAKAPI_PORT=3000

# Set to false after creating the first user (recommended for single-user instances)
WAKAPI_ALLOW_SIGNUP=true

# Set to false when served over HTTPS (inverted logic)
WAKAPI_INSECURE_COOKIES=false

# Logging
WAKAPI_LOG_LEVEL=info

#############################################
# Database (shared between Postgres and Wakapi)
#############################################

DB_TYPE=postgres
DB_HOST=wakapi_postgres
DB_PORT=5432
DB_NAME=wakapi
DB_USER=wakapi
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=false

#############################################
# Timezone
#############################################

TZ=Europe/Paris
